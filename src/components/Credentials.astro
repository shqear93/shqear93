---
import { certifications, awards } from '../data/content';
---

<section id="credentials">
  <div class="wrap">
    <div class="section-label reveal">cat credentials.json</div>
    <div class="cred-grid">
      <div class="reveal">
        <h4 class="mono block-title">certifications</h4>
        <ul class="cred-list">
          {certifications.map((c) => (
            <li>
              <span class="cred-name">{c.name}</span>
              <span class="mono cred-meta">{c.issuer} · {c.year}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="reveal">
        <h4 class="mono block-title">awards</h4>
        <ul class="cred-list">
          {awards.map((a) => (
            <li>
              <span class="cred-name">{a.name}</span>
              <span class="mono cred-meta">{a.note} · {a.year}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .cred-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 40px;
  }

  .block-title {
    font-size: 12px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 14px;
  }

  .cred-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .cred-list li {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }

  .cred-list li:last-child {
    border-bottom: none;
  }

  .cred-name {
    color: var(--text);
    font-size: 14.5px;
  }

  .cred-meta {
    font-size: 12px;
    color: var(--text-faint);
  }
</style>
