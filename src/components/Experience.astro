---
import { experience } from '../data/content';
---

<section id="experience">
  <div class="wrap">
    <div class="section-label reveal">cat experience.log</div>
    <div class="timeline">
      {experience.map((role, i) => (
        <div class="entry reveal" style={`--i: ${Math.min(i, 3)}`}>
          <div class="entry-head">
            <div>
              <h3>{role.role}</h3>
              <div class="company mono">
                {role.companyUrl ? (
                  <a href={role.companyUrl} target="_blank" rel="noopener">{role.company}</a>
                ) : (
                  role.company
                )}
              </div>
            </div>
            <div class="period mono">{role.period}</div>
          </div>
          <ul>
            {role.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 36px;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 8px;
    top: 6px;
    bottom: 6px;
    width: 1px;
    background: var(--border);
  }

  .entry {
    position: relative;
    padding-left: 32px;
  }

  .entry::before {
    content: '';
    position: absolute;
    left: 3px;
    top: 8px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--green);
  }

  .entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .entry-head h3 {
    font-size: 1.05rem;
  }

  .company {
    font-size: 13px;
    color: var(--text-faint);
    margin-top: 2px;
  }

  .period {
    font-size: 12.5px;
    color: var(--text-faint);
    white-space: nowrap;
  }

  .entry ul {
    margin: 0;
    padding-left: 18px;
    color: var(--text-muted);
  }

  .entry li {
    margin-bottom: 8px;
    font-size: 14.5px;
  }

  .entry li:last-child {
    margin-bottom: 0;
  }
</style>
