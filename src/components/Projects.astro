---
import { projects } from '../data/content';
---

<section id="projects">
  <div class="wrap">
    <div class="section-label reveal">ls -la projects/</div>
    <div class="project-grid">
      {projects.map((p) => (
        <article class="panel project-card reveal">
          <div class="term-chrome">
            <span class="term-dot red"></span>
            <span class="term-dot amber"></span>
            <span class="term-dot green"></span>
            <span class="term-title mono">{p.name.toLowerCase().replace(/\s+/g, '-')}.md</span>
          </div>
          <div class="project-body">
            <div class="project-head">
              <h3>{p.name}</h3>
              <span class="mono period">{p.period}</span>
            </div>
            <p class="tagline">{p.tagline}</p>

            <div class="project-section">
              <span class="mini-label mono">problem</span>
              <p>{p.problem}</p>
            </div>
            <div class="project-section">
              <span class="mini-label mono">architecture</span>
              <p>{p.architecture}</p>
            </div>
            <div class="project-section">
              <span class="mini-label mono">outcome</span>
              <p>{p.outcome}</p>
            </div>

            <div class="stack">
              {p.stack.map((t) => (
                <span class="tag">{t}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .project-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .project-card {
    overflow: hidden;
  }

  .project-body {
    padding: 22px 24px 26px;
  }

  .project-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 6px;
  }

  .project-head h3 {
    font-size: 1.2rem;
  }

  .period {
    font-size: 12px;
    color: var(--text-faint);
    white-space: nowrap;
  }

  .tagline {
    color: var(--green);
    font-size: 14.5px;
    margin: 0 0 18px;
  }

  .project-section {
    margin-bottom: 14px;
  }

  .project-section p {
    margin: 4px 0 0;
    font-size: 14.5px;
    color: var(--text-muted);
  }

  .mini-label {
    font-size: 11px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }
</style>
