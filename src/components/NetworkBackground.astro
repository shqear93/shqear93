---
---

<canvas id="network-bg" aria-hidden="true"></canvas>
<canvas id="cursor-glow" aria-hidden="true"></canvas>

<script>
  const canvas = document.getElementById('network-bg');
  const cursorCanvas = document.getElementById('cursor-glow');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canvas instanceof HTMLCanvasElement && !reduceMotion) {
    const ctx = canvas.getContext('2d');
    const ctxCursor = cursorCanvas.getContext('2d');
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const LINK_DIST = 150;
    const SPEED = 0.03;
    const HOVER_RADIUS = 140;
    const TOUCH_RADIUS = 22;
    const HEAT_TIME = 2200;
    const COOL_TIME = 800;

    let width = 0;
    let height = 0;
    let nodes = [];
    let pulses = [];
    let shorts = [];
    let cursorArcs = [];
    let fires = [];
    let pointerHeat = 0;

    const mouse = { x: -9999, y: -9999, active: false };
    window.addEventListener(
      'mousemove',
      (e) => {
        mouse.x = e.clientX;
        mouse.y = e.clientY;
        mouse.active = true;
      },
      { passive: true }
    );
    window.addEventListener('mouseleave', () => {
      mouse.active = false;
    });

    function lerpColor(c1, c2, t) {
      return [0, 1, 2].map((i) => Math.round(c1[i] + (c2[i] - c1[i]) * t));
    }

    function heatColor(heat) {
      if (heat <= 0) return [61, 220, 132];
      if (heat < 0.5) return lerpColor([61, 220, 132], [232, 179, 44], heat / 0.5);
      return lerpColor([232, 179, 44], [255, 90, 50], (heat - 0.5) / 0.5);
    }

    function nodeCount() {
      const area = width * height;
      return Math.min(90, Math.max(30, Math.round(area / 18000)));
    }

    function makeNode() {
      return {
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * SPEED,
        vy: (Math.random() - 0.5) * SPEED,
        heat: 0,
      };
    }

    function resize() {
      width = window.innerWidth;
      height = window.innerHeight;
      canvas.width = width * dpr;
      canvas.height = height * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cursorCanvas.width = width * dpr;
      cursorCanvas.height = height * dpr;
      ctxCursor.setTransform(dpr, 0, 0, dpr, 0, 0);

      const target = nodeCount();
      if (nodes.length === 0) {
        nodes = Array.from({ length: target }, makeNode);
      } else if (nodes.length < target) {
        while (nodes.length < target) nodes.push(makeNode());
      } else {
        nodes.length = target;
      }
    }

    resize();
    window.addEventListener('resize', resize);
    document.documentElement.classList.add('custom-cursor');

    let running = true;
    let lastTime = performance.now();

    document.addEventListener('visibilitychange', () => {
      running = document.visibilityState === 'visible';
      if (running) {
        lastTime = performance.now();
        requestAnimationFrame(frame);
      }
    });

    function frame(now) {
      if (!running || !ctx) return;
      const dt = Math.min(now - lastTime, 48);
      lastTime = now;

      ctx.clearRect(0, 0, width, height);

      const burned = [];
      let cursorProximity = 0;
      let cursorHeat = 0;

      for (let idx = 0; idx < nodes.length; idx++) {
        const n = nodes[idx];
        let slowdown = 1;

        if (mouse.active) {
          const dx = n.x - mouse.x;
          const dy = n.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < HOVER_RADIUS) {
            slowdown = Math.max(0.06, dist / HOVER_RADIUS);
            const closeness = 1 - dist / HOVER_RADIUS;
            if (closeness > cursorProximity) cursorProximity = closeness;
            if (n.heat > cursorHeat) cursorHeat = n.heat;
          }

          if (dist < TOUCH_RADIUS) {
            n.heat = Math.min(1, n.heat + dt / HEAT_TIME);
          } else {
            n.heat = Math.max(0, n.heat - dt / COOL_TIME);
          }
        } else {
          n.heat = Math.max(0, n.heat - dt / COOL_TIME);
        }

        if (n.heat >= 1) {
          fires.push({ x: n.x, y: n.y, t: 0, duration: 1100, particles: [] });
          burned.push(idx);
          continue;
        }

        n.x += n.vx * dt * slowdown;
        n.y += n.vy * dt * slowdown;
        if (n.x < 0 || n.x > width) n.vx *= -1;
        if (n.y < 0 || n.y > height) n.vy *= -1;
        n.x = Math.max(0, Math.min(width, n.x));
        n.y = Math.max(0, Math.min(height, n.y));
      }

      if (burned.length > 0) {
        const burnedSet = new Set(burned);
        nodes = nodes.filter((_, i) => !burnedSet.has(i));
        // Indices shift once nodes are removed, so any in-flight effects
        // referencing old indices would now point at the wrong node.
        pulses = [];
        shorts = [];
        cursorArcs = [];
        for (let k = 0; k < burned.length; k++) {
          setTimeout(
            () => {
              nodes.push(makeNode());
            },
            1200 + Math.random() * 900
          );
        }
      }

      const activeEdges = [];
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const a = nodes[i];
          const b = nodes[j];
          const dx = a.x - b.x;
          const dy = a.y - b.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < LINK_DIST) {
            const alpha = (1 - dist / LINK_DIST) * 0.5;
            ctx.strokeStyle = `rgba(61, 220, 132, ${alpha})`;
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
            activeEdges.push([i, j]);
          }
        }
      }

      // Occasionally spark a traveling light pulse along a live connection.
      if (activeEdges.length > 0 && pulses.length < 14 && Math.random() < 0.06) {
        const [i, j] = activeEdges[Math.floor(Math.random() * activeEdges.length)];
        pulses.push({
          from: Math.random() < 0.5 ? i : j,
          to: Math.random() < 0.5 ? j : i,
          t: 0,
          speed: 0.0009 + Math.random() * 0.0006,
        });
      }

      pulses = pulses.filter((p) => p.t < 1);
      for (const p of pulses) {
        p.t += p.speed * dt;
        const a = nodes[p.from];
        const b = nodes[p.to];
        if (!a || !b) continue;
        const x = a.x + (b.x - a.x) * p.t;
        const y = a.y + (b.y - a.y) * p.t;
        const fade = Math.sin(Math.PI * p.t);

        ctx.save();
        ctx.shadowColor = 'rgba(120, 255, 190, 1)';
        ctx.shadowBlur = 14;
        ctx.beginPath();
        ctx.arc(x, y, 2.2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(196, 255, 220, ${0.85 * fade + 0.15})`;
        ctx.fill();
        ctx.restore();
      }

      for (const n of nodes) {
        const [r, g, b] = heatColor(n.heat);
        ctx.save();
        ctx.shadowColor = `rgba(${r}, ${g}, ${b}, 0.9)`;
        ctx.shadowBlur = 6 + n.heat * 16;
        ctx.beginPath();
        ctx.arc(n.x, n.y, 1.6 + n.heat * 2.4, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r}, ${g}, ${b}, 0.85)`;
        ctx.fill();
        ctx.restore();
      }

      // Rare ambient electrical short between two network nodes, unrelated to the cursor.
      if (activeEdges.length > 0 && shorts.length < 1 && Math.random() < 0.0025) {
        const [i, j] = activeEdges[Math.floor(Math.random() * activeEdges.length)];
        shorts.push({ i, j, t: 0, duration: 260 + Math.random() * 220 });
      }

      shorts = shorts.filter((s) => s.t < s.duration);
      for (const s of shorts) {
        s.t += dt;
        const a = nodes[s.i];
        const b = nodes[s.j];
        if (!a || !b) continue;
        if (Math.random() < 0.7) {
          drawArc(a.x, a.y, b.x, b.y, 12, 1.3, 0.6 + Math.random() * 0.4);
        }
      }

      // Cursor arcs: any node within range can spark a jolt straight to the pointer.
      // The closer a node is, the more often and more violently it arcs.
      if (mouse.active) {
        for (let idx = 0; idx < nodes.length; idx++) {
          const n = nodes[idx];
          const dx = n.x - mouse.x;
          const dy = n.y - mouse.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist >= HOVER_RADIUS) continue;
          const intensity = 1 - dist / HOVER_RADIUS;
          const alreadyArcing = cursorArcs.some((a) => a.nodeIdx === idx);
          if (!alreadyArcing && cursorArcs.length < 8 && Math.random() < intensity * intensity * 0.2) {
            cursorArcs.push({
              nodeIdx: idx,
              t: 0,
              duration: 160 + Math.random() * 140,
              intensity,
            });
          }
        }
      }

      cursorArcs = cursorArcs.filter((a) => a.t < a.duration && nodes[a.nodeIdx]);

      // The pointer heats up from being arced at — multiple simultaneous arcs
      // (or closer, more intense ones) stack and heat it faster than one alone.
      const arcHeatInput = cursorArcs.reduce((sum, a) => sum + a.intensity, 0);
      if (arcHeatInput > 0) {
        pointerHeat = Math.min(1, pointerHeat + (arcHeatInput * dt) / 900);
      } else {
        pointerHeat = Math.max(0, pointerHeat - dt / 700);
      }

      for (const a of cursorArcs) {
        a.t += dt;
        const n = nodes[a.nodeIdx];
        if (!n || Math.random() >= 0.75) continue;
        drawArc(
          n.x,
          n.y,
          mouse.x,
          mouse.y,
          6 + a.intensity * 16,
          1.1 + a.intensity * 1,
          0.45 + a.intensity * 0.55,
          14 + a.intensity * 14
        );
      }

      // Fire: a node that overheated flickers upward like a flame, then burns out.
      fires = fires.filter((fire) => fire.t < fire.duration);
      for (const fire of fires) {
        fire.t += dt;
        if (fire.t < fire.duration - 250 && fire.particles.length < 26) {
          for (let k = 0; k < 2; k++) {
            fire.particles.push({
              age: 0,
              life: 380 + Math.random() * 380,
              x: fire.x + (Math.random() - 0.5) * 4,
              y: fire.y,
              vx: (Math.random() - 0.5) * 0.018,
              vy: -(0.075 + Math.random() * 0.085),
            });
          }
        }

        fire.particles = fire.particles.filter((p) => p.age < p.life);

        ctx.save();
        ctx.globalCompositeOperation = 'lighter';
        for (const p of fire.particles) {
          p.age += dt;
          p.x += p.vx * dt;
          p.y += p.vy * dt;
          const life = p.age / p.life;
          const radius = Math.max(0.1, 5.5 * (1 - life * 0.7));
          const color =
            life < 0.35
              ? [255, 245, 200]
              : life < 0.7
                ? [255, 150, 60]
                : [180, 50, 30];
          const alpha = 1 - life;

          const gradient = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, radius);
          gradient.addColorStop(0, `rgba(${color[0]}, ${color[1]}, ${color[2]}, ${alpha})`);
          gradient.addColorStop(1, `rgba(${color[0]}, ${color[1]}, ${color[2]}, 0)`);

          ctx.beginPath();
          ctx.arc(p.x, p.y, radius, 0, Math.PI * 2);
          ctx.fillStyle = gradient;
          ctx.fill();
        }
        ctx.restore();
      }

      // The pointer itself: a soft glowing ring that brightens near a node
      // and shifts hot as it charges one up. Drawn on its own top-layer
      // canvas so it stays visible over panels/text, not just open background.
      ctxCursor.clearRect(0, 0, width, height);
      if (mouse.active) {
        const pulse = 0.5 + 0.5 * Math.sin(now / 450);
        const displayHeat = Math.max(cursorHeat, pointerHeat);
        const [cr, cg, cb] = heatColor(displayHeat);
        const coreRadius = 2 + displayHeat * 1.6;
        const ringRadius = 7 + cursorProximity * 5 + displayHeat * 4 + pulse * 2.5;

        ctxCursor.save();
        ctxCursor.shadowColor = `rgba(${cr}, ${cg}, ${cb}, 1)`;
        ctxCursor.shadowBlur = 8 + cursorProximity * 14 + displayHeat * 14;
        ctxCursor.strokeStyle = `rgba(${cr}, ${cg}, ${cb}, ${0.3 + pulse * 0.2 + cursorProximity * 0.3})`;
        ctxCursor.lineWidth = 1.4;
        ctxCursor.beginPath();
        ctxCursor.arc(mouse.x, mouse.y, ringRadius, 0, Math.PI * 2);
        ctxCursor.stroke();

        ctxCursor.beginPath();
        ctxCursor.arc(mouse.x, mouse.y, coreRadius, 0, Math.PI * 2);
        ctxCursor.fillStyle = `rgba(${cr}, ${cg}, ${cb}, 0.9)`;
        ctxCursor.fill();
        ctxCursor.restore();
      }

      requestAnimationFrame(frame);

      function drawArc(x1, y1, x2, y2, jitterAmount, lineWidth, alpha, blur) {
        const dx = x2 - x1;
        const dy = y2 - y1;
        const len = Math.sqrt(dx * dx + dy * dy) || 1;
        const nx = -dy / len;
        const ny = dx / len;
        const segments = 5;

        ctx.save();
        ctx.shadowColor = 'rgba(230, 255, 240, 1)';
        ctx.shadowBlur = blur ?? 18;
        ctx.strokeStyle = `rgba(230, 255, 240, ${alpha})`;
        ctx.lineWidth = lineWidth;
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        for (let k = 1; k < segments; k++) {
          const t = k / segments;
          const jitter = (Math.random() - 0.5) * jitterAmount;
          ctx.lineTo(x1 + dx * t + nx * jitter, y1 + dy * t + ny * jitter);
        }
        ctx.lineTo(x2, y2);
        ctx.stroke();
        ctx.restore();
      }
    }

    requestAnimationFrame(frame);
  }
</script>

<style>
  #network-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    width: 100vw;
    height: 100vh;
    opacity: 0.6;
    pointer-events: none;
  }

  #cursor-glow {
    position: fixed;
    inset: 0;
    z-index: 9999;
    width: 100vw;
    height: 100vh;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #network-bg,
    #cursor-glow {
      display: none;
    }
  }
</style>
