---
import { profile } from '../data/content';

const links = [
  { href: '#about', label: 'about' },
  { href: '#experience', label: 'experience' },
  { href: '#projects', label: 'projects' },
  { href: '#skills', label: 'skills' },
  { href: '#contact', label: 'contact' },
];
---

<nav class="site-nav">
  <div class="wrap nav-inner">
    <a href="#" class="brand mono">khaled@portfolio<span class="cursor">_</span></a>
    <div class="links mono" id="nav-links">
      {links.map((l) => (
        <a href={l.href} data-nav-link={l.href.slice(1)}>{l.label}</a>
      ))}
      <a href={profile.resumeMain} target="_blank" rel="noopener" class="btn resume-link">resume ↗</a>
    </div>
  </div>
</nav>

<script>
  const navLinks = document.querySelectorAll('#nav-links a[data-nav-link]');
  const sections = Array.from(navLinks)
    .map((a) => document.getElementById(a.getAttribute('data-nav-link') || ''))
    .filter((el) => el !== null);

  const setActive = (id) => {
    navLinks.forEach((a) => {
      a.classList.toggle('active', a.getAttribute('data-nav-link') === id);
    });
  };

  const spy = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible.length > 0) {
        setActive(visible[0].target.id);
      }
    },
    { rootMargin: '-56px 0px -70% 0px', threshold: 0 }
  );

  sections.forEach((section) => spy.observe(section));
</script>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 14, 10, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .brand {
    font-size: 14px;
    color: var(--text);
  }

  .cursor {
    color: var(--green);
    animation: blink 1.1s steps(1) infinite;
  }

  @keyframes blink {
    50% { opacity: 0; }
  }

  .links {
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 13px;
  }

  .links a {
    color: var(--text-muted);
  }

  .links a:hover {
    color: var(--green);
    text-decoration: none;
  }

  .links a.active {
    color: var(--green);
    position: relative;
  }

  .links a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -8px;
    height: 2px;
    background: var(--green);
    border-radius: 2px;
  }

  .resume-link {
    padding: 6px 12px;
    font-size: 12px;
  }

  @media (max-width: 640px) {
    .links {
      gap: 12px;
    }
    .links a:not(.resume-link) {
      display: none;
    }
  }
</style>
